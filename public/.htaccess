<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Nao reescreve a pasta da API
  RewriteRule ^api/ - [L]

  # Se for arquivo ou diretorio que existe, entrega direto
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Tudo o mais cai no index.html (SPA fallback)
  RewriteRule . /index.html [L]
</IfModule>

# index.html NUNCA pode ser cacheado pelo browser — senao ele tenta carregar
# chunks JS antigos depois de um deploy novo (hashes diferentes) e quebra a SPA.
<IfModule mod_headers.c>
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Assets com hash no nome (Vite gera) podem ser cacheados ad eternum
  <FilesMatch "\.(js|css|woff2?|png|jpg|jpeg|webp|svg|gif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
